# 部署到公网服务器时使用：
# 1. 复制到项目根目录并改名为 .env（与 docker-compose.yml 同级）
#    cp deploy/.env.example .env
# 2. 修改下面几项后，在项目根目录执行 docker-compose up -d

# 必填：生产环境用随机密钥，可用命令生成：openssl rand -base64 48
DJANGO_SECRET_KEY=请改成随机长字符串

# 必填：你的服务器公网 IP 或域名，多个用逗号分隔
# 例如：42.123.45.67  或  api.yourname.com
DJANGO_ALLOWED_HOSTS=*

# 必填：允许手机 App 跨域请求，必须为 true
CORS_ALLOW_ALL_ORIGINS=true

# 可选：若想改数据库密码，与下面 MYSQL_ROOT_PASSWORD 保持一致
# MYSQL_ROOT_PASSWORD=你的强密码
# MYSQL_DATABASE=elderlycare
# DB_PASSWORD=你的强密码
